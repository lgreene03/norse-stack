# Norse Stack — environment template.
#
# Copy to `.env` and replace the placeholders with real local values:
#   cp .env.example .env
#
# docker-compose.yml reads these via ${VAR:-default}. The defaults baked into
# compose keep `docker compose up` working out-of-the-box for local dev, but a
# real deployment MUST override every value here. NEVER commit a populated .env.

# ── Datastore credentials ─────────────────────────────────────────────────
# Postgres password for the Muninn metadata DB (user: muninn).
MUNINN_DB_PASSWORD=change-me-muninn-db
# Postgres password for the Huginn DB (user: postgres).
HUGINN_DB_PASSWORD=change-me-huginn-db

# ── Object storage (MinIO / S3) ───────────────────────────────────────────
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-secret

# ── Observability ─────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# ── Control-plane bearer tokens ───────────────────────────────────────────
# Gate the mutating HTTP endpoints on Huginn and Sleipnir. Auth fails closed
# when set; leave empty ONLY for a fully trusted local network.
HUGINN_API_TOKEN=localdev-change-me
SLEIPNIR_ADMIN_TOKEN=localdev-change-me

# ── Python analytics services: CORS hardening (optional) ──────────────────
# The read-only HTTP APIs on odin/bragi/huginn-ai/news-sentinel default to
# Access-Control-Allow-Origin: * to keep local dashboards working. In a
# hardened deployment set this to the single dashboard origin instead, e.g.
# ACCESS_CONTROL_ALLOW_ORIGIN=https://dashboards.internal.example
# Leaving it unset preserves the permissive "*" default (non-breaking).
ACCESS_CONTROL_ALLOW_ORIGIN=*
